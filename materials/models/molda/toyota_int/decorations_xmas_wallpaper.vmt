"VertexLitGeneric"
{
	"$basetexture" "models/molda/toyota_int/decorations_xmas_wallpaper"

	"$color2" "[0.9 0.9 0.8]"

	"$selfillum" "0"
	"$selfillummask" "models/molda/toyota_int/decorations_xmas_wallpaper_mask"
	"$selfillumtint" "[ 5 5 5 ]"

	"$surfaceprop" "Metal"

	"$envmap" "models/molda/toyota_int/environment"

	"$envmaptint" "[0 0.4 0.8]"

	"$nodecal" "1"
	"$nocull" "0"

	$envmaptint_on "[0 0.2 0.4]"
	$envmaptint_off "[0 0.05 0.1]"

	"Proxies"
	{
		TARDIS_Power2 {
			onVar "$envmaptint_on"
			offVar "$envmaptint_off"
			resultVar "$envmaptint"
		}
	}
}
