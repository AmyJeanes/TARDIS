"VertexLitGeneric"
{
	"$basetexture" "models/molda/misc/tardis_pumpkin"
	"$surfaceprop" "Flesh"

	"$selfillum" "1"
	"$selfillummask" "models/molda/misc/tardis_pumpkin_emit"
	"$selfillumtint" "[1 1 1]"
	"$sine" "1"

	"$envmap" "models/molda/toyota_int/environment"
	"$envmaptint" "[0.25 0.25 0.25]"
	"$color2" "[5 5 5]"

	Proxies {
		Sine {
			sineperiod 2
			sinemin 0.5
			sinemax 1
			resultVar $sine
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[0]"
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[1]"
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[2]"
		}
	}
}
